---
import Layout from '../layouts/Layout.astro';
import TimeConverter from '../components/TimeConverter';
---

<Layout title="Free World Time Converter — Convert time zones instantly" description="The fastest time zone converter. Type '4pm Mumbai to London' and get the answer instantly.">
  <header class="app-header">
    <div class="app-header-inner">
      <a href="/" class="app-logo">freeworldtimeconverter.com</a>
      <span class="app-tagline">Convert any timezone instantly</span>
    </div>
  </header>

  <main>
    <TimeConverter client:load />
  </main>
</Layout>
